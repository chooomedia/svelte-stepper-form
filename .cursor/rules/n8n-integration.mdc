## Webhook Integration Pattern

### 1. Type Definitions

```typescript
// shared/types/n8n.types.ts
export interface N8nWebhookPayload {
  workflow_id: string;
  execution_id: string;
  timestamp: number;
  data: Record<string, any>;
}

export interface StepperWebhookData extends N8nWebhookPayload {
  data: {
    step: number;
    formData: FormData;
    validationResult: ValidationResult;
    metadata: {
      user_id: string;
      session_id: string;
      ip: string;
    };
  };
