2. Webhook Handler
javascript// src/lib/webhooks/n8n.js
import { n8nConfig } from '$lib/config/n8n.config';

export async function triggerN8nWorkflow(workflowId, data) {
  const webhookUrl = `${n8nConfig.baseUrl}/webhook/${workflowId}`;

  try {
    const response = await fetch(webhookUrl, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-N8N-API-KEY': n8nConfig.apiKey
      },
      body: JSON.stringify({
        ...data,
        timestamp: Date.now(),
        source: 'svelte-stepper'
      })
    });

    if (!response.ok) {
      throw new Error(`Webhook failed: ${response.statusText}`);
    }

    return await response.json();
  } catch (error) {
    console.error(`[n8n Webhook Error]:`, error);
    // Implement retry logic or fallback
    throw error;
  }
}
3. Store Integration
javascript// src/lib/stores/n8nStore.js
import { writable, derived } from 'svelte/store';
import { triggerN8nWorkflow } from '$lib/webhooks/n8n';

export const n8nWorkflows = writable({
  onStepComplete: 'workflow_123',
  onFormSubmit: 'workflow_456',
  onValidationFail: 'workflow_789'
});

export function createN8nIntegratedStore() {
  const store = writable({
    currentStep: 0,
    formData: {},
    webhookStatus: 'idle'
  });

  return {
    ...store,
    nextStepWithWebhook: async () => {
      store.update(s => ({ ...s, webhookStatus: 'pending' }));

      try {
        const state = get(store);
        await triggerN8nWorkflow('onStepComplete', {
          step: state.currentStep,
          formData: state.formData
        });

        store.update(s => ({
          ...s,
          currentStep: s.currentStep + 1,
          webhookStatus: 'success'
        }));
      } catch (error) {
        store.update(s => ({ ...s, webhookStatus: 'error' }));
      }
    }
  };
}
