## Form Handling

### Form Store Pattern

```javascript
// src/lib/stores/formStore.js
import { writable, get } from "svelte/store";

export function createFormStore(initialValues = {}) {
  const values = writable(initialValues);
  const errors = writable({});
  const touched = writable({});
  const isSubmitting = writable(false);

  function setFieldValue(field, value) {
    values.update((v) => ({ ...v, [field]: value }));
  }

  function setFieldError(field, error) {
    errors.update((e) => ({ ...e, [field]: error }));
  }

  function setFieldTouched(field, isTouched = true) {
    touched.update((t) => ({ ...t, [field]: isTouched }));
  }

  function validateField(field, value) {
    // Your validation logic here
    const error = validateValue(field, value);
    setFieldError(field, error);
    return !error;
  }

  function handleSubmit(onSubmit) {
    return async (event) => {
      event.preventDefault();
      isSubmitting.set(true);

      try {
        const currentValues = get(values);
        await onSubmit(currentValues);
      } catch (error) {
        console.error("Form submission error:", error);
      } finally {
        isSubmitting.set(false);
      }
    };
  }

  return {
    values,
    errors,
    touched,
    isSubmitting,
    setFieldValue,
    setFieldError,
    setFieldTouched,
    validateField,
    handleSubmit,
    reset: () => {
      values.set(initialValues);
      errors.set({});
      touched.set({});
      isSubmitting.set(false);
    },
  };
}
```

## Actions & Directives

### Custom Actions

```javascript
// src/lib/actions/validation.js
export function validate(node, options) {
  let { schema, onError } = options;

  function handleBlur(event) {
    const value = node.value;
    const result = schema.safeParse(value);

    if (!result.success) {
      onError(result.error);
      node.setAttribute("aria-invalid", "true");
    } else {
      node.setAttribute("aria-invalid", "false");
    }
  }

  node.addEventListener("blur", handleBlur);

  return {
    update(newOptions) {
      schema = newOptions.schema;
      onError = newOptions.onError;
    },
    destroy() {
      node.removeEventListener("blur", handleBlur);
    },
  };
}

// Usage in component
// <input use:validate={{ schema: emailSchema, onError: handleError }} />
```

### Transition Actions

```javascript
// src/lib/transitions/stepper.js
import { cubicOut } from "svelte/easing";

export function stepTransition(
  node,
  { delay = 0, duration = 300, easing = cubicOut } = {}
) {
  const style = getComputedStyle(node);
  const opacity = +style.opacity;
  const transform = style.transform === "none" ? "" : style.transform;

  return {
    delay,
    duration,
    easing,
    css: (t) => `
      transform: ${transform} translateX(${(1 - t) * 100}%);
      opacity: ${t * opacity};
    `,
  };
}
```

