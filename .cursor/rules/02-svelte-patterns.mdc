# You are a Svelte Expert implementing best practices

## Store Management

### Centralized State Architecture

```javascript
// src/lib/stores/stepperStore.js
import { writable, derived } from "svelte/store";

// Core state
export const currentStep = writable(0);
export const formData = writable({});
export const validation = writable({});

// Derived states
export const progress = derived(
  [currentStep],
  ([$currentStep]) => ($currentStep / totalSteps) * 100
);

// Custom store with methods
function createStepperStore() {
  const { subscribe, set, update } = writable({
    currentStep: 0,
    formData: {},
    validation: {},
    history: [],
  });

  return {
    subscribe,
    nextStep: () =>
      update((state) => ({
        ...state,
        history: [...state.history, state.currentStep],
        currentStep: state.currentStep + 1,
      })),
    prevStep: () =>
      update((state) => ({
        ...state,
        currentStep: state.history.pop() || 0,
        history: state.history,
      })),
    reset: () =>
      set({ currentStep: 0, formData: {}, validation: {}, history: [] }),
  };
}

export const stepper = createStepperStore();
```

